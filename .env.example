# ==========================================
# ProjectX Backend — Environment Variables
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas or local replica set)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/projectx?retryWrites=true&w=majority

# Redis (OTP store, token blacklist, cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMS Provider (console = log to terminal, twilio, msg91)
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=PROJX

# Twilio (if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MSG91 (if SMS_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Email notifications (Nodemailer / SMTP)
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MasterX <no-reply@masterx.in>"

# App
APP_NAME=ProjectX
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GEOCODING_PROVIDER=locationiq
LOCATIONIQ_BASE_URL=https://us1.locationiq.com
LOCATIONIQ_ACCESS_TOKEN=your-locationiq-access-token
LOCATIONIQ_USER_AGENT=ProjectX/1.0 (location-service)

# Admin
ADMIN_EMAIL=admin@projectx.in
ADMIN_PASSWORD=admin123456
